# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/naija_threads

# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=replace-me-with-a-long-random-string
